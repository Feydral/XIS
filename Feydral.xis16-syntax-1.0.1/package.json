{
  "name": "xis16-syntax",
  "publisher": "Feydral",
  "author": "Feydral",
  "displayName": "Xis16 Assembly",
  "description": "Syntax Highlighting for Xis16 Assembly",
  "version": "1.0.1",
  "engines": { "vscode": "^1.0.0" },
  "main": "./extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "languages": [
      {
        "id": "xis16",
        "aliases": ["Xis16 Assembly"],
        "extensions": [".xis16"]
      }
    ],
    "grammars": [
      {
        "language": "xis16",
        "scopeName": "source.xis16",
        "path": "./syntaxes/xis16.tmLanguage.json"
      }
    ]
  }
}
